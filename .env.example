# ── LLM API Keys (required) ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# ── LLM Models (optional overrides) ──────────────────────────────────────
# OPENAI_MODEL=gpt-5
# GEMINI_MODEL=gemini-2.5-flash

# ── Complexity Routing Threshold ─────────────────────────────────────────
# Queries with score >= this go to OpenAI; below this go to Gemini.
# Range: 0.0 – 1.0  (default: 0.4)
# COMPLEXITY_THRESHOLD=0.4

# ── Retrieval ─────────────────────────────────────────────────────────────
# RETRIEVAL_K=3              # final docs returned to the LLM
# RETRIEVAL_CANDIDATES=6     # initial candidates before RLHF re-ranking

# ── RLHF Score Weights ────────────────────────────────────────────────────
# combined = SIMILARITY_WEIGHT * cosine_score + FEEDBACK_WEIGHT * rlhf_score
# SIMILARITY_WEIGHT=0.7
# FEEDBACK_WEIGHT=0.3

# ── Embedding Model (HuggingFace, no API key needed) ─────────────────────
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ─────────────────────────────────────────────────────────────
# CHROMA_PERSIST_DIR=./chroma_db
# CHROMA_COLLECTION_NAME=rag_documents

# ── File Upload ───────────────────────────────────────────────────────────
# MAX_FILE_SIZE_MB=50
